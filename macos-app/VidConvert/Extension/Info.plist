<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- TEMPLATE: build-app.sh copies this per preset and stamps CFBundleIdentifier,
	     CFBundleDisplayName (the Finder menu label), and VidConvertPresetID. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>TEMPLATE-DISPLAY-NAME</string>
	<key>CFBundleExecutable</key>
	<string>VidConvertAction</string>
	<key>CFBundleIdentifier</key>
	<string>TEMPLATE-BUNDLE-ID</string>
	<key>VidConvertPresetID</key>
	<string>TEMPLATE-PRESET-ID</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>VidConvertAction</string>
	<key>CFBundlePackageType</key>
	<string>XPC!</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<!-- Show only for selections containing at least one movie/video file.
			     Containers with no UTI claim on a bare system (mkv/webm/…) won't
			     activate the menu item unless another installed app registers them —
			     drag-and-drop onto the app still accepts those (QueueModel fallback list). -->
			<key>NSExtensionActivationRule</key>
			<string>SUBQUERY(extensionItems, $item, SUBQUERY($item.attachments, $attachment, ANY $attachment.registeredTypeIdentifiers UTI-CONFORMS-TO "public.movie" OR ANY $attachment.registeredTypeIdentifiers UTI-CONFORMS-TO "public.video").@count &gt;= 1).@count &gt;= 1</string>
			<key>NSExtensionServiceAllowsFinderPreviewItem</key>
			<true/>
			<key>NSExtensionServiceFinderPreviewIconName</key>
			<string>NSActionTemplate</string>
			<!-- Viewer, NEVER Editor: S2 verified Editor role makes Finder stage the
			     originals into hidden NSIRD dirs expecting replacements (files "vanish"). -->
			<key>NSExtensionServiceRoleType</key>
			<string>NSExtensionServiceRoleTypeViewer</string>
		</dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.services</string>
		<key>NSExtensionPrincipalClass</key>
		<string>VidConvertAction.ActionRequestHandler</string>
	</dict>
</dict>
</plist>
