<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>VidConvert</string>
	<key>CFBundleIdentifier</key>
	<string>local.vidconvert</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>VidConvert</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<!-- Movie/video document claim: required for the M2 Quick Action handoff —
	     LaunchServices refuses NSWorkspace open(_:withApplicationAt:) from the
	     sandboxed appex unless the target app claims the documents' type.
	     Viewer role + Alternate rank: never becomes the double-click default. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Video</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.movie</string>
				<string>public.video</string>
			</array>
		</dict>
		<dict>
			<!-- Containers macOS often has no UTI claim for (QueueModel fallback list) —
			     extension-based claim so "Open With" offers VidConvert for these too. -->
			<key>CFBundleTypeName</key>
			<string>Video container</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>mkv</string>
				<string>webm</string>
				<string>flv</string>
				<string>wmv</string>
				<string>ts</string>
				<string>m2ts</string>
			</array>
		</dict>
	</array>
	<!-- vidconvert://convert?preset=<id>&file=<path>… — how the Quick Action appexes
	     hand over the selection WITH the chosen preset (file opens carry no metadata). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>VidConvert conversion request</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>vidconvert</string>
			</array>
		</dict>
	</array>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHighResolutionCapable</key>
	<true/>
</dict>
</plist>
